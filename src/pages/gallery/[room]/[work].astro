---
import { getCollection } from 'astro:content';
import RoomPage from '../../../components/RoomPage.astro';

export async function getStaticPaths() {
  const galleries = await getCollection('galleries');
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { room: work.data.gallery, work: work.id },
    props: { gallery: galleries.find((g) => g.id === work.data.gallery)!, openSlug: work.id },
  }));
}

const { gallery, openSlug } = Astro.props;
---

<RoomPage gallery={gallery} openSlug={openSlug} />
