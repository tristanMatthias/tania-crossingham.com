---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import WorkStrip from '../components/WorkStrip.astro';
import CtaPanel from '../components/CtaPanel.astro';
import homepage from '../content/homepage.json';
import { url } from '../lib/url';

/**
 * The strip shows the works curated on the Homepage singleton
 * (a drag-sortable reference list in the CMS), in list order.
 */
const allWorks = await getCollection('works');
const slugOf = (ref: string) =>
  ref.replace(/^\/?src\/content\/works\//, '').replace(/\/index\.md$/, '');

const works = (homepage.works ?? [])
  .map((ref) => allWorks.find((w) => w.id === slugOf(ref)))
  .filter((entry) => entry != null)
  .map((entry) => ({
    title: entry.data.title,
    meta: entry.data.meta,
    image: entry.data.image,
    href: url(`/gallery/${entry.data.gallery}/${entry.id}/`),
  }));
---

<Base mode="strip">
  <WorkStrip
    works={works}
    midAfter={3}
    primaryCta={{ label: 'Commission a work', href: url('/commissions/') }}
    secondaryCta={{ label: 'View galleries', href: url('/gallery/') }}
  >
    <div class="quote-card" slot="mid">
      <div class="diamonds gold">◆ ◆ ◆</div>
      <div class="quote-heading">{homepage.quoteHeading}</div>
      <div class="quote-body muted">{homepage.quoteBody}</div>
      <a class="btn btn--link label" href={url('/commissions/')}>{homepage.ctaButton} →</a>
    </div>
    <CtaPanel slot="end" variant="strip" />
  </WorkStrip>
</Base>

<style>
  .quote-card {
    flex: none;
    width: 320px;
    max-width: 80vw;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .diamonds {
    font-size: var(--text-label);
    letter-spacing: 0.5em;
  }

  .quote-heading {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.3;
  }

  .quote-body {
    font-size: 12px;
    line-height: var(--leading-body);
  }

  .btn--link {
    align-self: flex-start;
  }
</style>
