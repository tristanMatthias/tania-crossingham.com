---
import { getCollection } from 'astro:content';
import settings from '../content/settings.json';
import { url } from '../lib/url';

interface Props {
  active?: string;
}

const { active } = Astro.props;

/**
 * Nav is a sitewide ordered list of page references in Site settings
 * (drag-sortable in the CMS). Gallery is pinned first — it's a route to
 * the rooms, not a page entry.
 */
const pages = await getCollection('pages');
const slugOf = (ref: string) =>
  ref.replace(/^\/?src\/content\/pages\//, '').replace(/\.md$/, '');

const nav = [
  { id: 'gallery', label: 'Gallery', href: url('/gallery/') },
  ...(settings.nav ?? [])
    .map((ref) => pages.find((p) => p.id === slugOf(ref)))
    .filter((p) => p != null)
    .map((p) => ({ id: p.id, label: p.data.title, href: url(`/${p.id}/`) })),
];
---

<header>
  <a class="wordmark" href={url('/')}>
    <span class="name">{settings.siteName}</span>
    <span class="credentials label-sm muted">{settings.credentials}</span>
  </a>
  <nav class="label">
    {
      nav.map((item) => (
        <a href={item.href} class:list={[{ active: active === item.id }]}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    padding: 28px var(--page-x) 0;
    flex: none;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .name {
    font-family: var(--font-serif);
    font-size: var(--text-wordmark);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .credentials {
    letter-spacing: var(--tracking-wider);
    font-size: var(--text-credentials);
  }

  nav {
    display: flex;
    gap: 34px;
    color: var(--color-muted);
    padding-top: 6px;
    flex-wrap: wrap;
  }

  nav a:hover {
    color: var(--color-ink);
  }

  nav a.active {
    color: var(--color-gold);
  }

  @media (max-width: 900px) {
    header {
      flex-direction: column;
      gap: 18px;
    }

    nav {
      gap: 20px;
      padding-top: 0;
    }
  }
</style>
