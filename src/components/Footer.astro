---
import settings from '../content/settings.json';

const socials = [
  { label: 'Instagram', href: settings.social.instagram },
  { label: 'YouTube', href: settings.social.youtube },
  { label: 'Patreon', href: settings.social.patreon },
  { label: 'Newsletter', href: settings.social.newsletter },
].filter((s) => s.href);
---

<footer class="label muted">
  <span>{settings.siteName} — {settings.location}</span>
  <span class="socials">
    {socials.map((s) => <a href={s.href} target="_blank" rel="noopener">{s.label}</a>)}
  </span>
</footer>

<style>
  footer {
    flex: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    padding: 40px var(--page-x);
    letter-spacing: 0.18em;
  }

  .socials {
    display: flex;
    gap: 26px;
    flex-wrap: wrap;
  }

  a:hover {
    color: var(--color-ink);
  }

  @media (max-width: 760px) {
    footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
